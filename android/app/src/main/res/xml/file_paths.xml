<?xml version="1.0" encoding="utf-8"?>
<paths>
    <external-path name="external_files" path="."/>
    <!-- Camera plugin often writes here; without this, FileProvider cannot share the image with UCrop. -->
    <external-cache-path name="external_cache" path="."/>
    <cache-path name="cache" path="."/>
    <files-path name="files" path="."/>
    <!-- Flutter getApplicationDocumentsDirectory() lives here (sibling of files/). -->
    <files-path name="app_flutter" path="../app_flutter"/>
</paths>
